/*  the actual, scannable QR code for `site.url`, generated offline (qrcode,
    33x33 modules, quiet-zone trimmed). The white background rect is dropped so
    the code sits transparent on its surroundings, and the module stroke is
    switched to `currentColor` so it inherits the wrapper's text colour. `class`
    is forwarded to the <svg> for sizing (e.g. "h-16 w-16").  */

import { site } from "../data/site.ts"

interface Props {
    class?: string
}

const { class: className = "h-16 w-16" } = Astro.props
---
<svg
    viewBox="0 0 33 33"
    shape-rendering="crispEdges"
    class={className}
    role="img"
    aria-label={`QR code linking to ${site.url}`}
>
