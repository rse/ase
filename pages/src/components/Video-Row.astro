/*  one row of the two-column USP/video list. The USP text and the demo video
    occupy the two columns; their order is *swapped* on alternating rows
    (odd-indexed rows place the video first) to create the zig-zag rhythm.
    On narrow screens the columns stack and the USP always leads.  */

import VideoEmbed   from "./Video-Embed.astro"
import Terminal     from "./Terminal.astro"
import type { Highlights } from "../data/highlights.ts"

interface Props {
    usp:   Highlights
    index: number
}

const { usp, index } = Astro.props
const reversed       = index % 2 === 1

/*  reveal each column from its own outer screen edge so the two halves
    converge toward the row center. The `data-reveal` value naming is
    inverted vs. intuition ("left" starts off-screen to the right), so the
    visually-left column uses "right" and the visually-right column uses
    "left". On reversed (zig-zag) rows the video sits left and the text
    right, so the directions swap with `reversed`.  */
const textReveal  = reversed ? "left"  : "right"
const videoReveal = reversed ? "right" : "left"

/*  wrap the showcased skill's leading `/ase-xxx-xxx` command keyword in the
    Terminal component's `**...**` highlight markers, so it is tinted in the
    brand accent while the arguments stay in the foreground.  */
const spaceIdx = usp.skill.indexOf(" ")
const skillCmd = spaceIdx === -1 ?
    `**${usp.skill}**` :
    `**${usp.skill.slice(0, spaceIdx)}**${usp.skill.slice(spaceIdx)}`
---
<div class="ase-grid-split">
    <div class:list={[ "relative isolate", reversed ? "lg:order-2" : "lg:order-1" ]} data-reveal={textReveal}>
        {/* blue radial glow behind the text block, bleeding off the viewport
            on the text's side of the row (left on normal rows, right on the
            reversed/zig-zag rows). */}
        <div
            class:list={[ "pointer-events-none absolute top-1/2 -z-10 h-[260%] w-[240%] -translate-y-1/2",
                reversed ? "left-0 translate-x-[10%]" : "right-0 -translate-x-[10%]" ]}
            style="background: radial-gradient(ellipse 70% 60% at center, color-mix(in oklch, var(--brand-500) 30%, transparent), transparent 80%);"
            aria-hidden="true"
        ></div>
        <p class="ase-eyebrow">{usp.eyebrow}</p>
        <h3 class="ase-h3">{usp.title}</h3>
        <p class="mt-4 text-foreground-secondary ase-justify" set:html={usp.body}></p>
        <Terminal class="mt-5" prefix="Claude Code" commands={[ skillCmd ]}/>
    </div>
    <div class:list={[ reversed ? "lg:order-1" : "lg:order-2" ]} data-reveal={videoReveal}>
        <VideoEmbed name={usp.video} label={usp.title}/>
    </div>
</div>
