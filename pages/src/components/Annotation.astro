/*  hand-drawn annotation: a curved white arc/arrow sweeping from the
    top-right down to the bottom-left, with a short white text caption
    placed above the arc. Intended to be absolutely positioned by the
    caller as an overlay that points at a nearby UI element. The arrow
    head sits at the arc's bottom-left (target) end. The caption is
    supplied via the default slot.  */

interface Props {
    class?: string
}
const { class: className } = Astro.props

/*  arc geometry (SVG user units): a gentle curve from the top-right
    corner down to the bottom-left, where the arrow head points at the
    annotated target.  */
const W = 200  /*  overall width   */
const H = 110  /*  overall height  */

/*  the arc path: start at top-right, sweep leftwards along the top to
    the top-left, then hook downwards to the target point near the
    bottom-left. Two cubic Bézier segments give a smooth "L"-shaped hook.  */
const arc = [
    "M 58 12",                     /*  start: top-right                  */
    "C 20 14, 6 44, 30 90"         /*  single smooth sweep down to target */
].join(" ")
---
<div class={`annotation annotation-cycle pointer-events-none select-none ${className ?? ""}`}>
    <svg
        class="block h-auto w-full overflow-visible"
        width={W}
        height={H}
        viewBox={`0 0 ${W} ${H}`}
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
    >
        <defs>
            {/* soft shadow so the mid-blue arc reads over any background */}
            <filter id="annotation-shadow" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="1" stdDeviation="1.2" flood-color="#000000" flood-opacity="0.45" />
            </filter>
        </defs>

        {/* curved arc body */}
        <path
            d={arc}
            fill="none"
            stroke="var(--brand-800)"
            stroke-width="3"
            stroke-linecap="round"
            filter="url(#annotation-shadow)"
        />

        {/* arrow head at the bottom-left (target) end of the arc, pointing
            down-and-leftwards where the hook terminates */}
        <path
            d="M 30 90 L 16 84 M 30 90 L 34 76"
            fill="none"
            stroke="var(--brand-800)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            filter="url(#annotation-shadow)"
        />
    </svg>

    {/* caption text, supplied by the caller via the default slot, centred
        above the arc which now sweeps along the top edge. The caller
        positions the outer wrapper (absolutely), so this anchors against
        that wrapper. */}
    <div
        class="annotation-label absolute inset-x-0 -top-3 translate-x-7 -rotate-2 text-center leading-[1.1] text-brand-500"
        style="font-family: 'TypoPRO Kalam', cursive; font-size: 18px; text-shadow: 0 1px 2px rgba(0,0,0,0.5);">
        <slot />
    </div>
</div>

<style>
    /*  wait hidden (10s), fade in (2s), hold (10s), fade out (2s),
        then restart from the beginning; total cycle = 24s  */
    .annotation-cycle {
        animation: annotation-cycle 24s ease-in-out infinite;
    }

    @keyframes annotation-cycle {
        0%      { opacity: 0; }   /*  start hidden for 10s    */
        41.67%  { opacity: 0; }   /*  end of hidden wait      */
        50%     { opacity: 1; }   /*  fade in over 2s         */
        91.67%  { opacity: 1; }   /*  hold visible for 10s    */
        100%    { opacity: 0; }   /*  fade out over 2s        */
    }

    @media (prefers-reduced-motion: reduce) {
        .annotation-cycle {
            animation: none;
            opacity: 1;
        }
    }
</style>
