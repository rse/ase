/*  "Setup" section: prerequisites prose plus terminal-style boxes with the
    install / update / uninstall commands (each row has a "❯" prompt and a copy
    button wired by the Clipboard-Copy component in BaseLayout).  */

import SectionGlow from "./Section-Glow.astro"
import Terminal    from "./Terminal.astro"
---
<section id="setup" class="relative isolate mx-auto max-w-4xl px-6 py-8">
    <SectionGlow variant="section" side="left" />

    <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">
            Easy <span class="text-accent">Setup</span>
        </h2>
        <p class="text-left mt-4 text-foreground-secondary">
            As a prerequisite, please install the Agentic AI Coding tool{" "}
            <a href="https://claude.com/products/claude-code">Claude Code</a>{" "}
            (or with reduced support the alternatives <a href="https://github.com/features/copilot/cli">GitHub Copilot CLI</a>{" "}
            or <a href="https://github.com/openai/codex">OpenAI Codex</a>) and
            the essential run-time environment{" "}
            <a href="https://nodejs.org/">Node.js</a> for your particular platform.
        </p>
        <p class="indent-paragraph text-foreground-secondary">
            Then execute the two commands below under <b>Installation</b>. The first command installs
            the <b>ASE</b> Command-Line Interface (CLI).
            The second command uses this CLI to install
            the <b>ASE</b> Plugin into your Agentic AI Coding tool.
            The <code>ase setup update</code> keeps <b>ASE</b> up to date and
            the <code>ase setup uninstall</code> will reverse the
            installation residue-free again at any time.
            The <code>--tool claude</code> is the default and not necessary
            for the mainstream tool <a href="https://claude.com/products/claude-code">Claude Code</a>.
        </p>
    </header>

    <div data-reveal>
        <Terminal
            class="mx-auto mt-8 max-w-2xl"
            copy={true}
            title="Installation"
            commands={[
                "**npm** install -g @rse/ase",
                "**ase** setup install **[**--tool claude**|**copilot**|**codex**]**"
            ]}
        />
    </div>

    <div data-reveal>
        <Terminal
            class="mx-auto mt-8 max-w-2xl"
            copy={true}
            title="Updating"
            commands={[
                "**ase** setup update **[**--tool claude**|**copilot**|**codex**]**"
            ]}
        />
    </div>

    <div data-reveal>
        <Terminal
            class="mx-auto mt-8 max-w-2xl"
            copy={true}
            title="Uninstallation"
            commands={[
                "**ase** setup uninstall **[**--tool claude**|**copilot**|**codex**]**"
            ]}
        />
    </div>

    <header class="mt-12 mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-1xl font-bold sm:text-2xl">
            Power-Up with <span class="text-accent">Foreign Services</span>
        </h2>
        <p class="mt-4 text-foreground-secondary text-left">
            <b>ASE</b> can <i>optionally</i> leverage additional
            Model-Context-Protocol (MCP) servers for contacting foreign
            LLM services (<b>OpenAI ChatGPT</b>, <b>Google Gemini</b>, <b>DeepSeek</b>, <b>xAI
            Grok</b>, <b>Alibaba Qwen</b>, or <b>Z.AI GLM</b>) via MCP-to-OpenAI servers
            and Web Search services (<b>Brave</b>, <b>Perplexity</b> or <b>Exa</b>) via their
            dedicated MCP servers. You only need the access tokens
            of those services at hand. <b>ASE</b> will just add the
            corresponding local MCP servers to the Agentic AI Coding
            tool.
        </p>
        <blockquote class="mt-4 text-left border-l-4 border-accent bg-background-elevated/40 px-6 py-0 text-foreground-secondary">
            <b class="text-accent">NOTICE:</b>
            <span class="mt-1 block text-foreground-secondary">
            These add-on MCP servers are <b>NOT</b> required
            for <b>ASE</b> to work. They are fully
            optional when using <b>ASE</b>, but will
            power up some of the <b>ASE</b> skills (like{" "}
            <code>ase-meta-chat</code>, <code>ase-meta-search</code>,
            and <code>ase-meta-quorum</code>) with additional
            functionality.
            </span>
        </blockquote>
    </header>

    <div data-reveal>
        <Terminal
            class="mx-auto mt-8 max-w-2xl"
            copy={true}
            title="MCP Installation"
            commands={[
                "**ase** setup mcp list",
                "export ASE_MCP_KEY_**<service>**=\"**<token>**\"",
                "**ase** setup mcp activate **[**--tool claude**|**copilot**|**codex**]**"
            ]}
        />
    </div>

    <div data-reveal>
        <Terminal
            class="mx-auto mt-8 max-w-2xl"
            copy={true}
            title="MCP Uninstallation"
            commands={[
                "**ase** setup mcp deactivate **[**--tool claude**|**copilot**|**codex**]**"
            ]}
        />
    </div>

</section>
