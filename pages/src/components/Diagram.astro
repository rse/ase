/*  a click-to-zoom diagram: the SVG shown inline as a framed, hover-lifting
    button that opens the shared image modal (wired in BaseLayout via the
    `data-image-*` attributes). `class` is forwarded to the wrapping <div> so
    the caller can set the two-column order (e.g. "lg:order-2").  */

interface Props {
    src:    string
    label:  string
    class?: string
}

const { src, label, class: className = "" } = Astro.props
---
<div class={className}>
    <button
        type="button"
        class="group block w-full cursor-zoom-in overflow-hidden rounded-xl border border-border-strong p-4 shadow-xl transition-transform hover:-translate-y-0.5 sm:p-6"
        data-image-src={src}
        data-image-label={label}
        aria-label={`Enlarge ${label}`}
    >
        <img
            src={src}
            alt={label}
            loading="lazy"
            class="mx-auto block h-auto w-full"
        />
    </button>
</div>
