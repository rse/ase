/*  a click-to-zoom diagram: the SVG shown inline as a framed, hover-lifting
    button that opens the shared image modal (wired in BaseLayout via the
    `data-image-*` attributes). `class` is forwarded to the wrapping <div> so
    the caller can set the two-column order (e.g. "lg:order-2").  */

interface Props {
    src:    string
    label:  string
    class?: string
}

const { src, label, class: className = "" } = Astro.props
---
<div class={className}>
    <button
        type="button"
        class="group relative block w-full cursor-zoom-in overflow-hidden rounded-xl border border-border-strong p-4 shadow-xl transition-transform hover:-translate-y-0.5 sm:p-6"
        data-image-src={src}
        data-image-label={label}
        aria-label={`Enlarge ${label}`}
    >
        <img
            src={src}
            alt={label}
            loading="lazy"
            class="mx-auto block h-auto w-full"
        />

        {/* centered zoom-button overlay (mirrors the Video-Embed play button)
            to indicate the diagram opens in the image modal on click. */}
        <span class="pointer-events-none absolute inset-0 grid place-items-center">
            <span class="grid h-16 w-16 place-items-center rounded-full bg-[color-mix(in_oklch,var(--accent)_60%,black)]/60 text-2xl font-bold text-white shadow-lg backdrop-blur-xs transition-colors group-hover:bg-[color-mix(in_oklch,var(--accent)_80%,black)]/60">
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" />
                    <line x1="16" y1="16" x2="21" y2="21" />
                    <line x1="11" y1="8" x2="11" y2="14" />
                    <line x1="8" y1="11" x2="14" y2="11" />
                </svg>
            </span>
        </span>
    </button>
</div>
