/*  floating site header: the ASE logo, the in-page section nav (driven by the
    Scroll-Spy via `data-navlink`/`nav-spy`), the GitHub link, the (hidden)
    theme switcher, and the scroll-progress bar along its bottom edge.  */

import { site }      from "../data/site.ts"
import LogoASE       from "./Logo-ASE.astro"
import LogoGitHub    from "./Logo-GitHub.astro"
import ThemeSwitcher from "./Theme-Switcher.astro"
import ProgressBar   from "./Progress-Bar.astro"
---
<header
    class="fixed inset-x-0 top-0 z-50 border-b border-border/60 backdrop-blur"
    style="background: linear-gradient(to right,
        color-mix(in oklch, var(--background) 80%, transparent),
        color-mix(in oklch, color-mix(in oklch, var(--background) 70%, var(--brand-600)) 80%, transparent),
        color-mix(in oklch, var(--background) 80%, transparent)
    );"
>
    <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
        <div class="flex items-center gap-3">
            <a href="/" class="flex items-center gap-3 font-display text-lg font-bold">
                <LogoASE class="h-[1.0rem] w-auto" idPrefix="ase-navlogo" />
            </a>
            <nav class="ml-8 flex items-center gap-5 text-base text-foreground-secondary">
                <a href="#highlights" data-navlink data-label="Highlights" class="nav-spy transition-colors">
                    Highlights
                </a>
                <a href="#setup" data-navlink data-label="Setup" class="nav-spy transition-colors">
                    Setup
                </a>
                <a href="#usage" data-navlink data-label="Usage" class="nav-spy transition-colors">
                    Usage
                </a>
                <a href="#architecture" data-navlink data-label="Architecture" class="nav-spy transition-colors">
                    Architecture
                </a>
            </nav>
        </div>
        <nav class="flex items-center gap-5 text-base text-foreground-secondary">
            <span class="flex items-center gap-2">
                <a href="https://github.com/rse" aria-label="Dr. Ralf S. Engelschall on GitHub" class="flex items-center">
                    <img src="/assets/rse-signet.svg" alt="Dr. Ralf S. Engelschall" class="h-[1.2rem] w-auto"/>
                </a>
                <a href="#author" data-navlink data-label="Author" class="nav-spy transition-colors">
                    Author
                </a>
            </span>
            <a href={site.repo} class="nav-link inline-flex items-center gap-1.5 transition-colors">
                <LogoGitHub class="h-4 w-4"/>
                Project
            </a>
            <ThemeSwitcher class="hidden"/>
        </nav>
    </div>
    <ProgressBar />
</header>

<style is:global>
    /*  non-spy nav link (e.g. "Project"): on hover it adopts the foreground
        colour (white), mirroring the .nav-spy links. The `!important` beats the
        unlayered global `a {}` rule.  */
    .nav-link:hover { color: var(--foreground) !important; }
</style>
