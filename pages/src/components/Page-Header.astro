/*  floating site header: the ASE logo, the in-page section nav (driven by the
    Scroll-Spy via `data-navlink`/`nav-spy`), the GitHub link, the (hidden)
    theme switcher, and the scroll-progress bar along its bottom edge.  */

import { site }      from "../data/site.ts"
import LogoASE       from "./Logo-ASE.astro"
import LogoGitHub    from "./Logo-GitHub.astro"
import ThemeSwitcher from "./Theme-Switcher.astro"
import ProgressBar   from "./Progress-Bar.astro"
---
<header class="fixed inset-x-0 top-0 z-50 border-b border-border/60">
    {/*  header background as a separate, absolutely-positioned layer rather than
         a `backdrop-blur` on the <header> itself: a `backdrop-filter` on the
         header would establish a backdrop root that nullifies the mobile nav
         panel's own blur (a descendant cannot re-blur an already-blurred
         ancestor). Keeping it a sibling layer lets the panel blur the page
         directly.  */}
    <div
        class="nav-bar-bg pointer-events-none absolute inset-0 -z-10"
        aria-hidden="true"
    ></div>
    <div class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-6 py-4 lg:max-w-6xl">
        <a href="/" class="flex items-center gap-3 font-display text-lg font-bold">
            <LogoASE class="h-[1.0rem] w-auto" idPrefix="ase-navlogo" />
        </a>

        {/*  hamburger toggle: visible only below the `lg` breakpoint, where the
             nav collapses into the `#nav-menu` panel below.  */}
        <button
            id="nav-toggle"
            type="button"
            aria-label="Toggle navigation menu"
            aria-controls="nav-menu"
            aria-expanded="false"
            class="flex cursor-grab items-center rounded-md border border-border px-2 py-1 text-foreground-secondary transition-colors hover:border-border-strong hover:text-foreground lg:hidden"
        >
            <span class="nav-toggle-open w-5 justify-center text-xl leading-none text-accent not-[.hidden]:inline-flex">☰</span><span class="nav-toggle-close hidden w-5 justify-center text-xl leading-none text-accent not-[.hidden]:inline-flex">✕</span>
        </button>

        {/*  the collapsible navigation panel: a horizontal in-line nav from the
             `lg` breakpoint upwards, and (below it) an auto-width drop-down panel
             anchored to the top-right of the header, toggled by `#nav-toggle`
             via the `data-open` attribute.  */}
        <div
            id="nav-menu"
            class="nav-menu-panel absolute right-6 top-full hidden w-auto flex-col items-end gap-y-1.5 rounded-md rounded-t-none border border-border/60 p-4 shadow-lg data-[open]:flex lg:static lg:top-auto lg:flex lg:w-auto lg:flex-1 lg:flex-row lg:items-center lg:justify-between lg:gap-x-5 lg:rounded-none lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none"
        >
            <nav class="flex min-w-0 flex-col flex-wrap items-end gap-x-3 gap-y-1 text-base text-foreground-secondary lg:ml-4 lg:flex-row lg:items-center">
                <a href="#highlights" data-navlink class="nav-spy transition-colors">
                    Highlights
                </a>
                <a href="#setup" data-navlink class="nav-spy transition-colors">
                    Setup
                </a>
                <a href="#usage" data-navlink class="nav-spy transition-colors">
                    Usage
                </a>
                <a href="#workflows" data-navlink class="nav-spy transition-colors">
                    Workflows
                </a>
                <a href="#design" data-navlink class="nav-spy transition-colors">
                    Design
                </a>
                <a href="#architecture" data-navlink class="nav-spy transition-colors">
                    Architecture
                </a>
                <a href="#compat" data-navlink class="nav-spy transition-colors">
                    Compatibility
                </a>
            </nav>
            <nav class="flex flex-col flex-wrap items-end gap-x-3 gap-y-1 text-base text-foreground-secondary lg:flex-row lg:items-center">
                <span class="flex items-center gap-2">
                    <a href="https://github.com/rse" aria-label="Dr. Ralf S. Engelschall on GitHub" class="flex items-center">
                        <img src="/assets/rse-signet.svg" alt="Dr. Ralf S. Engelschall" class="h-[1.2rem] w-auto"/>
                    </a>
                    <a href="#author" data-navlink class="nav-spy transition-colors">
                        Author
                    </a>
                </span>
                <a href={site.repo} class="nav-link inline-flex items-center gap-1.5 transition-colors">
                    <LogoGitHub class="h-4 w-4"/>
                    Project
                </a>
                <ThemeSwitcher class="hidden"/>
            </nav>
        </div>
    </div>
    <ProgressBar />
</header>

{/*  hamburger toggle: open/close the collapsed nav panel below the `lg`
     breakpoint, and auto-close it whenever a nav link is clicked.  */}
<script is:inline>
    (function () {
        const btn  = document.getElementById("nav-toggle")
        const menu = document.getElementById("nav-menu")
        if (!btn || !menu) return
        const setOpen = function (open) {
            if (open)
                menu.setAttribute("data-open", "")
            else
                menu.removeAttribute("data-open")
            btn.setAttribute("aria-expanded", open ? "true" : "false")
            btn.querySelector(".nav-toggle-open").classList.toggle("hidden", open)
            btn.querySelector(".nav-toggle-close").classList.toggle("hidden", !open)
        }
        btn.addEventListener("click", function () {
            setOpen(!menu.hasAttribute("data-open"))
        })
        menu.querySelectorAll("a").forEach(function (link) {
            link.addEventListener("click", function () { setOpen(false) })
        })

        /*  close the open panel when clicking anywhere outside of it or the
            toggle button (the toggle handles its own clicks above).  */
        document.addEventListener("click", function (ev) {
            if (!menu.hasAttribute("data-open"))
                return
            if (menu.contains(ev.target) || btn.contains(ev.target))
                return
            setOpen(false)
        })
    })()
</script>

<style is:global>
    /*  non-spy nav link (e.g. "Project"): on hover it adopts the foreground
        colour (white), mirroring the .nav-spy links. The `!important` beats the
        unlayered global `a {}` rule.  */
    .nav-link:hover { color: var(--foreground) !important; }

    /*  header background layer: the translucent brand gradient plus the frosted
        backdrop blur, kept off the <header> element itself (see the markup
        comment) so it does not trap the mobile nav panel's own blur.  */
    .nav-bar-bg {
        background: linear-gradient(to right,
            color-mix(in oklch, var(--background) 80%, transparent),
            color-mix(in oklch, color-mix(in oklch, var(--background) 70%, var(--brand-600)) 80%, transparent),
            color-mix(in oklch, var(--background) 80%, transparent)
        );
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
    }

    /*  the collapsed mobile drop-down panel: mirror the header's own translucent
        gradient background and backdrop blur so the open menu reads identically
        to the header bar it hangs from. Cleared again from the `lg` breakpoint
        upwards, where the nav is an inline, transparent part of the header.  */
    .nav-menu-panel {
        background: linear-gradient(to right,
            color-mix(in oklch, var(--background) 80%, transparent),
            color-mix(in oklch, color-mix(in oklch, var(--background) 70%, var(--brand-600)) 80%, transparent),
            color-mix(in oklch, var(--background) 80%, transparent)
        );
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
    }
    @media (width >= 64rem) {
        .nav-menu-panel {
            background: transparent;
            -webkit-backdrop-filter: none;
            backdrop-filter: none;
        }
    }
</style>
