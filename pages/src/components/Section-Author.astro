/*  "Author" section: a short portrait of the primary author Dr. Ralf S.
    Engelschall plus the motivation statement that drives ASE, rendered as a
    styled pull-quote.  */

import SectionGlow from "./Section-Glow.astro"
import LogoGitHub  from "./Logo-GitHub.astro"
import LogoRSE     from "./Logo-RSE.astro"

const contributors = [
    "Matthias Brusdeylins",
    "Jochen Hörtreiter",
    "Michael Kagel",
    "Maximilian Marsch",
    "Christian Reiber",
    "Zoltan Ruzman",
    "Michael Schäfer",
    "Markus Schnappinger",
    "Jan Tutas",
    "Linda Zeman",
]
---
<section id="author" class="relative isolate mx-auto max-w-4xl px-6 py-8">
    <SectionGlow variant="section" side="right"/>

    <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">
            About the <span class="text-accent">Author</span>
        </h2>
        <p class="mt-4 text-left text-foreground-secondary">
            <b>ASE</b> is primarily authored by
            <b>Dr. Ralf S. Engelschall</b> (abbreviated
            <b>RSE</b> and stylized <LogoRSE class="inline-block h-[1em] w-auto align-[-0.15em]"/>),
            a 53-year-old German <i>Computer Scientist</i>, <i>Executive Manager</i>, <i>Solution Architect</i> and <i>Software Artist</i>.
        </p>
    </header>

    <div class="mt-12 flex w-full flex-col items-center gap-16 sm:flex-row sm:items-start" data-reveal>
        <div class="w-full min-w-0 sm:basis-2/8 sm:shrink-0 sm:grow-0">
            <a href="https://github.com/rse" class="block overflow-hidden rounded-xl ring-1 ring-border-strong transition hover:ring-accent">
                <img src="/assets/rse-portrait.png" alt="Dr. Ralf S. Engelschall" class="aspect-[10/9] w-full object-cover" />
            </a>
            <a href="https://github.com/rse" class="mt-4 w-full inline-flex items-center justify-center gap-2 rounded-lg border border-border-strong px-3 py-2 font-semibold text-foreground transition-colors hover:border-accent hover:text-accent">
                <LogoGitHub class="h-5 w-5" />
                <b>Dr. Ralf S. Engelschall</b>
            </a>
        </div>
        <div class="w-full min-w-0 sm:basis-6/8">
            <p class="mt-1 text-left text-foreground-secondary [text-indent:2em]">
                <b>RSE</b> is <b>CTO msg group</b> and <b>Director msg Research</b> at <i>msg</i>
                &mdash; a Software Engineering company group with more than 11,000 people &mdash;,
                managing director and co-founder of <b>Software Engineering Academy (SEA)</b>,
                managing director and co-founder of <b>OpenPKG</b>,
                and especially also one of the founders of <b>Apache Software Foundation (ASF)</b>.
            </p>
            <p class="mt-1 text-left text-foreground-secondary [text-indent:2em]">
                <b>RSE</b> is a well-known <b>Open Source</b> authority for over 35 years
                and the founder and author of numerous popular software projects, like
                <b>Apache mod_rewrite</b>,
                <b>Apache mod_ssl</b>,
                <b>OpenSSL</b>,
                <b>OpenPKG</b>,
                <b>GNU Shtool</b>,
                <b>GNU Pth</b>,
                <b>OSSP uuid</b>,
                <b>ComponentJS</b>,
                <b>Studio-Canvas</b>,
                <b>Studio-AI</b>,
                <b>Rundown</b>,
                <b>Trait-TS</b>,
                <b>MQTT+</b>,
                and <a href="https://github.com/rse?tab=repositories">about 300 more</a>.
            </p>
            <p class="mt-1 text-left text-foreground-secondary [text-indent:2em]">
                You can follow <b>RSE</b> and his current <b>Open Source</b> software developments on
                <a href="https://github.com/rse" target="_blank">GitHub</a>,
                and follow him and his current (German) article publishing on
                <a href="https://www.linkedin.com/in/engelschall" target="_blank">LinkedIn</a>.
            </p>
        </div>
    </div>
</section>

<section id="contributors" class="relative isolate mx-auto max-w-4xl px-6 py-8">
    <SectionGlow variant="section" side="left" />
    <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">
            Thanks to the <span class="text-accent">Contributors</span>
        </h2>
        <p class="mt-4 text-left text-foreground-secondary">
            The <b>ASE</b> project received support from the following
            individual contributors, coming from both the industrial
            <b>Software Engineering</b> and <b>Open Source Software</b>
            contexts.
            <b>Many thanks to them for their valuable feedback and support!</b>
        </p>
    </header>

    <div class="mt-12 w-full" data-reveal>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
            {contributors.map((name) => (
                <div class="overflow-hidden rounded-xl border border-border-strong p-1 text-center text-accent">{name}</div>
            ))}
        </div>
    </div>
</section>

<section id="sponsors" class="relative isolate mx-auto max-w-4xl px-6 py-8 mb-24">
    <SectionGlow variant="section" side="left" />
    <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">
            Thanks to the <span class="text-accent">Sponsors</span>
        </h2>
        <p class="mt-4 text-left text-foreground-secondary">
            The <b>ASE</b> project is supported by the following
            organizations through time, material, knowledge, and/or experience.
            <b>Many thanks to them for their support!</b>
        </p>
    </header>

    <div class="mt-12 w-full" data-reveal>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-2">
            <div class="flex flex-col items-center gap-2 py-2 overflow-hidden rounded-xl border border-border-strong p-1 text-center text-foreground">
                <div class="flex flex-1 items-center justify-center">
                    <img src="/assets/msg-logo-white.svg" alt="msg systems ag" class="h-14 w-auto opacity-75" />
                </div>
                <div class="mb-2">msg systems ag</div>
            </div>
            <div class="flex flex-col items-center gap-2 py-2 overflow-hidden rounded-xl border border-border-strong p-1 text-center text-foreground">
                <div class="flex flex-1 items-center justify-center">
                    <img src="/assets/sea-logo-white.svg" alt="SEA Software Engineering Academy gGmbH" class="h-20 w-auto opacity-75" />
                </div>
                <div class="mb-2">SEA Software Engineering Academy gGmbH</div>
            </div>
        </div>
    </div>
</section>
