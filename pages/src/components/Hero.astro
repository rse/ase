import LogoASE      from "./Logo-ASE.astro"
import TypingDemo   from "./Typing-Demo.astro"
import Flag         from "./Flag.astro"
import Annotation   from "./Annotation.astro"
import HeroVideo    from "./Hero-Video.astro"
import ModalYouTube from "./Modal-YouTube.astro"
import {
    Swiper,
    SwiperWrapper,
    SwiperSlide
}                   from "astro-swiper"

/*  the single hero video: previewed inline (Hero-Video) and played in the
    page-root modal (Modal-YouTube), so id and label must match between both.  */
const video = { id: "yNFSVDRa_kM", label: "Agentic Software Engineering (ASE)" }

/*  rotating hero quotes, swipeable via the <Swiper> carousel below.  */
const quotes = [
    "Boost your daily productivity while<br/>keeping yourself in the driver's seat!",
    "Fuse Agentic AI Coding with<br/>traditional Software Engineering!",
    "Let the agent handle the chores while<br/>you stay in control of the craft!",
    "Various operation modes provided &mdash;<br/>you choose the best for the job!"
]

/*  GitHub badges via Shields.io: one shared URL helper and the plain badge
    list (the "project stars" badge is rendered separately below, as it
    carries the annotation and the hover guide).  */
const badgeURL = (path: string) =>
    `https://img.shields.io/${path}&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477`
const badges = [
    { href: "https://github.com/rse",              path: "github/stars/rse?logo=github&label=author%20stars",            alt: "github (author stars)"     },
    { href: "https://github.com/rse",              path: "github/followers/rse?logo=github&label=author%20followers",    alt: "github (author followers)" },
    { href: "https://github.com/rse/ase/releases", path: "github/v/release/rse/ase?logo=github&label=project%20release", alt: "github (release)"          }
]
---
<section class="relative isolate overflow-hidden">
    {/* hanging flag, carrying the sponsor logos as its overlay content */}
    <Flag class="absolute right-[5%] top-0 z-30 sm:right-[20%]">
        <div class="mb-2 flex flex-col items-center justify-center gap-4">
            <img src="/assets/sea-logo-white.svg" alt="SEA Software Engineering Academy gGmbH" class="w-25 h-auto opacity-75"/>
            <img src="/assets/msg-logo-white.svg" alt="msg systems ag" class="w-20 h-auto opacity-75"/>
        </div>
    </Flag>

    {/* radial wash */}
    <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background:
            radial-gradient(ellipse 60% 180% at 50% -20%, color-mix(in oklch, var(--brand-500) 30%, transparent), transparent 75%),
            linear-gradient(to bottom, var(--background-secondary), var(--background));"
        aria-hidden="true"
    ></div>

    <div class="mx-auto flex min-h-[88vh] max-w-4xl flex-col items-center justify-center px-6 pt-[6rem] pb-20 text-center">
        <div class="hero-stagger flex flex-col items-center">
            {/*  ASE logo and annotation  */}
            <div class="relative">
                <span
                    class="pointer-events-none absolute text-left right-full top-0 mr-8 hidden w-56 -rotate-2 leading-[1.10] text-brand-500 lg:block"
                    style="font-family: 'TypoPRO Kalam', cursive; font-size: 22px; letter-spacing: -0.03em;">
                    From a founder of the<br/>
                    Apache Software Foundation...
                </span>
                <LogoASE class="mb-4 h-auto w-32 sm:w-40" idPrefix="ase-hero-logo" />
            </div>

            {/* title */}
            <h1 class="max-w-full text-4xl font-bold break-words sm:text-6xl md:text-7xl">
                <span class="bg-gradient-to-b from-[var(--neutral-grad-from)] to-[var(--neutral-grad-to)] bg-clip-text text-transparent">
                    Agentic
                </span>{" "}
                <span class="bg-gradient-to-b from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    Software Engineering
                </span>
            </h1>

            {/* quotes — swipeable carousel, auto-rotating, with pagination */}
            <Swiper
                class="hero-quotes mt-6 w-full max-w-xl"
                options={{
                    direction:      "vertical",
                    allowTouchMove: false,
                    loop:           true,
                    autoplay:       { delay: 6000, disableOnInteraction: false },
                    pagination:     { el: ".swiper-pagination", clickable: true },
                    a11y:           { enabled: true },
                    keyboard:       { enabled: true }
                }}
            >
                <SwiperWrapper>
                    {quotes.map((quote) => (
                        <SwiperSlide class="flex items-center justify-center px-4 sm:px-10">
                            <blockquote class="border-l-8 border-brand-700 px-4 text-left text-xs italic leading-tight text-white sm:text-lg" set:html={quote}/>
                        </SwiperSlide>
                    ))}
                </SwiperWrapper>
            </Swiper>

            {/* GitHub badges */}
            <div class="relative z-40 mt-6 flex min-h-[28px] flex-wrap items-center justify-center gap-2">
                {badges.map((badge) => (
                    <a href={badge.href} class="inline-flex overflow-hidden rounded-md">
                        <img src={badgeURL(badge.path)} alt={badge.alt} />
                    </a>
                ))}
                <span class="group relative inline-flex">
                    <Annotation fade class="left-1/2 -translate-x-1/4">
                        If you like ASE,<br/>
                        please support it<br/>
                        by giving a star!<br/>
                        Many thanks.
                    </Annotation>
                    <a href="https://github.com/rse/ase" class="inline-flex overflow-hidden rounded-md">
                        <img src={badgeURL("github/stars/rse/ase?logo=github&label=project%20stars")} alt="github (project stars)" />
                    </a>
                    {/* on hover, reveal an animated guide showing how to give the
                        project a star, in a popup anchored below the badge. */}
                    <span class="pointer-events-none absolute right-0 top-full z-50 mt-3 origin-top-right scale-95 opacity-0 transition duration-200 group-hover:scale-100 group-hover:opacity-100">
                        <img
                            src="/assets/gh-star.gif"
                            alt="How to star the ASE project on GitHub"
                            loading="lazy"
                            class="block w-72 max-w-[80vw] rounded-lg border border-border-strong [filter:drop-shadow(0_5px_3px_rgba(0,0,0,0.35))] sm:w-96"
                        />
                    </span>
                </span>
            </div>

            {/* sub-title */}
            <p class="mt-6 max-w-2xl text-base sm:text-lg leading-snug text-foreground-secondary ase-justify">
                <b>Agentic Software Engineering (ASE)</b> is the opinionated{" "}
                <a href="https://github.com/rse/ase/blob/master/LICENSE.txt">Open Source</a>{" "}
                toolkit of renowned and prolific author <a href="#author">Dr. Ralf S. Engelschall</a>, for fusing the concepts of{" "}
                <b>Agentic AI Coding</b> and traditional <b>Software Engineering</b>.{" "}
                <b>ASE</b> ships as a plugin for the software development tool{" "}
                <a href="https://claude.com/product/claude-code">Anthropic Claude Code CLI</a> &mdash;
                and with reduced support also for the alternative
                tools <a href="https://github.com/features/copilot/cli">GitHub Copilot CLI</a> and{" "}
                <a href="https://github.com/openai/codex">OpenAI Codex CLI</a>.{" "}
                It comprises agent hooks, parametrizable agent skills, an underlying
                Model-Context-Protocol (MCP) service and a companion Command-Line Interface (CLI).
            </p>

            {/* second paragraph, with a YouTube preview floated top-right; the text
                flows around it on the left and, once the float ends, below
                full-width. The float is dropped on narrow viewports, where the
                video instead stacks above the text. */}
            <div class="w-full max-w-2xl">
                <div class="mb-4 w-full lg:float-right lg:mb-2 lg:ml-8 lg:w-[21%]">
                    <HeroVideo id={video.id} label={video.label}/>
                    <p class="mt-1.5 text-center text-xs text-accent">
                        Dr. Ralf S. Engelschall in a<br/>
                        studio interview on ASE
                    </p>
                </div>
                <p class="ase-indent-p text-base sm:text-lg leading-snug text-foreground-secondary ase-justify">
                    <b>ASE</b> incorporates reasonable methodology and automation aspects to support the
                    daily, recurring tasks of a <b>Software Developer</b> and <b>Software Architect</b>.
                    The comprehensive functionality spans from <i>brainstorming ideas</i>, <i>searching the
                    Web</i>, <i>asking foreign LLMs</i>,{" "}
                    <i>discovering components</i>, through <i>evaluating alternatives</i>,{" "}
                    <i>challenging statements</i>, <i>analyzing root causes</i>,{" "}
                    <i>managing tasks</i>, <i>grilling task plans</i>, all the way to <i>analyzing,
                    fixing, refactoring, and crafting code</i>, <i>reviewing changesets</i>,
                    and many more.
                </p>
            </div>

            {/* terminal-style typed out examples of ASE skill invocations */}
            <TypingDemo/>
        </div>
    </div>

    {/* scroll-down indicator (desktop only, fades against the hero base). */}
    <a
        href="#highlights"
        aria-label="Scroll to highlights"
        class="absolute inset-x-0 bottom-8 mx-auto hidden w-max flex-col items-center text-accent md:flex">
        <span class="chevron-bounce text-2xl leading-none">⌄</span>
    </a>
</section>

{/* rendered outside the Hero's <section> (which has isolate + overflow-hidden)
    so this fixed, full-viewport modal isn't clipped to / trapped inside its
    stacking context. */}
<ModalYouTube id={video.id} label={video.label}/>

<style is:global>
    /*  hero entrance animations:
        the hero children stagger in on load;
        the scroll-down chevron bounces.  */

    @keyframes hero-slide-up {
        from { opacity: 0; transform: translateY(80px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .hero-stagger > * {
        animation: hero-slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .hero-stagger > *:nth-child(1) { animation-delay: 0ms; }
    .hero-stagger > *:nth-child(2) { animation-delay: 90ms; }
    .hero-stagger > *:nth-child(3) { animation-delay: 180ms; }
    .hero-stagger > *:nth-child(4) { animation-delay: 270ms; }

    @keyframes chevron-bounce {
        0%, 100% { transform: translateY(0); opacity: 0.5; }
        50%      { transform: translateY(8px); opacity: 1; }
    }
    .chevron-bounce { animation: chevron-bounce 1.8s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
        .hero-stagger > *,
        .chevron-bounce { animation: none; }
    }

    /*  theme the swiper quote carousel to the brand palette. The carousel
        swipes vertically, so it needs a fixed height (the wrapper would
        otherwise collapse). Swiper's bundle CSS forces "margin: auto" on
        ".swiper" (centring it and defeating Tailwind's ml-* utilities), so
        the horizontal offset is set here instead: a left auto-margin nudges
        the carousel right while a right margin keeps it off the right edge.  */
    .hero-quotes.hero-quotes {
        --swiper-theme-color: var(--brand-500);
        --swiper-pagination-bullet-inactive-color: var(--brand-400);
        height: 3rem;
        margin-left:  auto;
        margin-right: 2rem;
        touch-action: pan-y;
    }

    /*  on small viewports the smaller quote font (text-xs) needs less
        vertical room, so shrink the fixed carousel height accordingly.  */
    @media (max-width: 639px) {
        .hero-quotes.hero-quotes {
            height: 2rem;
        }
    }
    .hero-quotes .swiper-slide {
        height: auto;
    }
</style>
