import LogoASE     from "./Logo-ASE.astro"
import TypingDemo  from "./Typing-Demo.astro"
import VersionFlag from "./Version-Flag.astro"
---
<section class="relative isolate overflow-hidden">
    {/* hanging version flag  */}
    <VersionFlag class="absolute right-[5%] top-0 z-30 sm:right-[20%]"/>

    {/* radial wash */}
    <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background:
            radial-gradient(ellipse 60% 180% at 50% -20%, color-mix(in oklch, var(--brand-500) 30%, transparent), transparent 75%),
            linear-gradient(to bottom, var(--background-secondary), var(--background));"
        aria-hidden="true"
    ></div>

    <div class="mx-auto flex min-h-[88vh] max-w-4xl flex-col items-center justify-center px-6 pt-28 pb-20 text-center">
        <div class="hero-stagger flex flex-col items-center">
            {/* ASE logo (inlined component, so its two fills can be themed) */}
            <LogoASE class="mb-8 h-auto w-32 sm:w-40" idPrefix="ase-hero-logo" />

            {/* title */}
            <h1 class="max-w-4xl text-6xl font-bold sm:text-6xl md:text-7xl">
                <span class="bg-gradient-to-b from-[var(--neutral-grad-from)] to-[var(--neutral-grad-to)] bg-clip-text text-transparent">
                    Agentic
                </span>
                <span class="bg-gradient-to-b from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    Software Engineering
                </span>
            </h1>

            {/* quote */}
            <div class="mt-8 max-w-2xl flex flex-wrap items-center justify-center gap-4">
                <blockquote class="border-l-8 border-brand-600 px-4 text-left text-lg italic leading-tight text-white">
                    Boost your daily productivity while<br/>
                    keeping yourself in the driver seat!
                </blockquote>
            </div>

            {/* GitHub badges */}
            <div class="mt-8 flex h-[28px] flex-wrap items-center justify-center gap-2">
                <a href="https://github.com/rse" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/stars/rse?logo=github&label=author%20stars&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (author stars)" />
                </a>
                <a href="https://github.com/rse" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/followers/rse?logo=github&label=author%20followers&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (author followers)" />
                </a>
                <a href="https://github.com/rse/ase" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/stars/rse/ase?logo=github&label=project%20stars&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (project stars)" />
                </a>
                <!--
                <a href="https://github.com/rse/ase/releases" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/v/release/rse/ase?logo=github&label=latest%20release&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (release)" />
                </a>
                -->
            </div>

            {/* sub-title */}
            <p class="mt-6 max-w-2xl text-lg text-foreground-secondary sm:text-xl text-left">
                The opinionated <b>Open Source</b> companion tooling of
                <a href="https://github.com/rse/">Dr. Ralf S. Engelschall</a>
                for fusing the concept of <b>Agentic AI Coding</b> and traditional <b>Software Engineering</b>
                in the software development tool <b>Anthropic Claude
                Code</b> &mdash; and with reduced support also in the alternative
                tool <b>GitHub Copilot CLI</b> or <b>OpenAI Codex</b>.
            </p>

            <p class="mt-4 max-w-2xl text-lg text-foreground-secondary sm:text-xl text-left">
                <b>ASE</b> ships with agent hooks, agent skills, an MCP
                service and a CLI, incorporating reasonable methodology
                and automation aspects, to support the recurring tasks of a
                <b>Software Developer</b> and <b>Software Architect</b>.
            </p>

            {/* terminal-style typed out examples of ASE skill invocations */}
            <TypingDemo/>

            {/* buttons */}
            <div class="mt-4 flex flex-wrap items-center justify-center gap-4">
                <a href="#highlights" class="rounded-lg border border-border-strong px-3 py-2 font-semibold text-foreground transition-colors hover:border-accent hover:text-accent">
                    See Highlights ↓
                </a>
                <a href="#setup" class="rounded-lg border border-border-strong px-3 py-2 font-semibold text-foreground transition-colors hover:border-accent hover:text-accent">
                    See Setup ↓
                </a>
                <a href="#usage" class="rounded-lg border border-border-strong px-3 py-2 font-semibold text-foreground transition-colors hover:border-accent hover:text-accent">
                    See Usage ↓
                </a>
                <a href="#usage" class="rounded-lg border border-border-strong px-3 py-2 font-semibold text-foreground transition-colors hover:border-accent hover:text-accent">
                    See Architecture ↓
                </a>
            </div>
        </div>
    </div>

    {/* scroll-down indicator (desktop only, fades against the hero base.) */}
    <a
        href="#highlights"
        aria-label="Scroll to highlights"
        class="absolute inset-x-0 bottom-8 mx-auto hidden w-max flex-col items-center text-accent md:flex">
        <span class="chevron-bounce text-2xl leading-none">⌄</span>
    </a>
</section>

<style is:global>
    /*  hero entrance animations:
        the hero children stagger in on load;
        the scroll-down chevron bounces.  */

    @keyframes hero-slide-up {
        from { opacity: 0; transform: translateY(80px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .hero-stagger > * {
        animation: hero-slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .hero-stagger > *:nth-child(1) { animation-delay: 0ms; }
    .hero-stagger > *:nth-child(2) { animation-delay: 90ms; }
    .hero-stagger > *:nth-child(3) { animation-delay: 180ms; }
    .hero-stagger > *:nth-child(4) { animation-delay: 270ms; }

    @keyframes chevron-bounce {
        0%, 100% { transform: translateY(0); opacity: 0.5; }
        50%      { transform: translateY(8px); opacity: 1; }
    }
    .chevron-bounce { animation: chevron-bounce 1.8s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
        .hero-stagger > *,
        .chevron-bounce { animation: none; }
    }
</style>
