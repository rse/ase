import LogoASE     from "./Logo-ASE.astro"
import TypingDemo  from "./Typing-Demo.astro"
import Flag        from "./Flag.astro"
import Annotation  from "./Annotation.astro"
import {
    Swiper,
    SwiperWrapper,
    SwiperSlide
}                  from "astro-swiper"

/*  rotating hero quotes, swipeable via the <Swiper> carousel below.  */
const quotes = [
    "Boost your daily productivity while<br/>keeping yourself in the driver's seat!",
    "Fuse Agentic AI Coding with<br/>traditional Software Engineering!",
    "Let the agent handle the chores while<br/>you stay in control of the craft!",
    "Various operation modes provided &mdash;<br/>you choose the best for the job!"
]
---
<section class="relative isolate overflow-hidden">
    {/* hanging flag, carrying the sponsor logos as its overlay content */}
    <Flag class="absolute right-[5%] top-0 z-30 sm:right-[20%]">
        <div class="mb-2 flex flex-col items-center justify-center gap-4">
            <img src="/assets/sea-logo-white.svg" alt="SEA Software Engineering Academy gGmbH" class="w-25 h-auto opacity-75"/>
            <img src="/assets/msg-logo-white.svg" alt="msg systems ag" class="w-20 h-auto opacity-75"/>
        </div>
    </Flag>

    {/* radial wash */}
    <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background:
            radial-gradient(ellipse 60% 180% at 50% -20%, color-mix(in oklch, var(--brand-500) 30%, transparent), transparent 75%),
            linear-gradient(to bottom, var(--background-secondary), var(--background));"
        aria-hidden="true"
    ></div>

    <div class="mx-auto flex min-h-[88vh] max-w-4xl flex-col items-center justify-center px-6 pt-28 pb-20 text-center">
        <div class="hero-stagger flex flex-col items-center">
            {/* ASE logo (inlined component, so its two fills can be themed) */}
            <LogoASE class="mb-4 h-auto w-32 sm:w-40" idPrefix="ase-hero-logo" />

            {/* title */}
            <h1 class="max-w-full text-4xl font-bold break-words sm:text-6xl md:text-7xl">
                <span class="bg-gradient-to-b from-[var(--neutral-grad-from)] to-[var(--neutral-grad-to)] bg-clip-text text-transparent">
                    Agentic
                </span>{" "}
                <span class="bg-gradient-to-b from-brand-400 to-brand-600 bg-clip-text text-transparent">
                    Software Engineering
                </span>
            </h1>

            {/* quotes — swipeable carousel, auto-rotating, with pagination */}
            <Swiper
                class="hero-quotes mt-8 w-full max-w-xl"
                options={{
                    direction:      "vertical",
                    allowTouchMove: false,
                    loop:           true,
                    autoplay:       { delay: 6000, disableOnInteraction: false },
                    pagination:     { el: ".swiper-pagination", clickable: true },
                    a11y:           { enabled: true },
                    keyboard:       { enabled: true }
                }}
            >
                <SwiperWrapper>
                    {quotes.map((quote) => (
                        <SwiperSlide class="flex items-center justify-center px-4 sm:px-10">
                            <blockquote class="border-l-8 border-brand-700 px-4 text-left text-sm italic leading-tight text-white sm:text-lg" set:html={quote}/>
                        </SwiperSlide>
                    ))}
                </SwiperWrapper>
            </Swiper>

            {/* GitHub badges */}
            <div class="mt-8 flex min-h-[28px] flex-wrap items-center justify-center gap-2">
                <a href="https://github.com/rse" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/stars/rse?logo=github&label=author%20stars&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (author stars)" />
                </a>
                <a href="https://github.com/rse" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/followers/rse?logo=github&label=author%20followers&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (author followers)" />
                </a>
                <a href="https://github.com/rse/ase/releases" class="inline-flex overflow-hidden rounded-md">
                    <img src="https://img.shields.io/github/v/release/rse/ase?logo=github&label=project%20release&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (release)" />
                </a>
                <span class="relative inline-flex">
                    <Annotation fade class="pointer-events-none absolute bottom-full left-1/2 z-30 hidden w-[200px] -translate-x-1/4 sm:block">
                        If you like ASE,<br/>
                        please support it<br/>
                        by giving a star!<br/>
                        Many thanks.
                    </Annotation>
                    <a href="https://github.com/rse/ase" class="inline-flex overflow-hidden rounded-md">
                        <img src="https://img.shields.io/github/stars/rse/ase?logo=github&label=project%20stars&style=for-the-badge&logoColor=%23e0f0ff&labelColor=%23225588&color=%23114477" alt="github (project stars)" />
                    </a>
                </span>
            </div>

            {/* sub-title */}
            <p class="mt-6 max-w-2xl text-lg text-foreground-secondary sm:text-xl text-left">
                The opinionated <a href="https://github.com/rse/ase/blob/master/LICENSE.txt">Open Source</a> companion
                toolkit of <a href="#author">Dr. Ralf S. Engelschall</a>{" "}
                for fusing the concept of <b>Agentic AI Coding</b> and traditional <b>Software Engineering</b>{" "}
                in the software development tool <a href="https://claude.com/product/claude-code">Anthropic Claude
                Code</a> &mdash; and with reduced support also in the alternative
                tool <a href="https://github.com/features/copilot/cli">GitHub Copilot CLI</a> or{" "}
                <a href="https://github.com/openai/codex">OpenAI Codex</a>.
            </p>

            <p class="mt-4 max-w-2xl text-lg text-foreground-secondary sm:text-xl text-left">
                <b>ASE</b> ships with agent hooks, agent skills, an underlying Model-Context-Protocol (MCP)
                service and a Command-Line Interface (CLI), incorporating reasonable methodology
                and automation aspects, to support the recurring tasks of a{" "}
                <b>Software Developer</b> and <b>Software Architect</b>.
            </p>

            {/* terminal-style typed out examples of ASE skill invocations */}
            <TypingDemo/>

            {/* buttons */}
            <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
                <a href="#highlights" class="ase-btn">
                    Highlights ↓
                </a>
                <a href="#setup" class="ase-btn">
                    Setup ↓
                </a>
                <a href="#usage" class="ase-btn">
                    Usage ↓
                </a>
                <a href="#workflows" class="ase-btn">
                    Workflows ↓
                </a>
            </div>
            <div class="mt-2 flex flex-wrap items-center justify-center gap-2">
                <a href="#design" class="ase-btn">
                    Design ↓
                </a>
                <a href="#architecture" class="ase-btn">
                    Architecture ↓
                </a>
                <a href="#compat" class="ase-btn">
                    Compatibility ↓
                </a>
            </div>
        </div>
    </div>

    {/* scroll-down indicator (desktop only, fades against the hero base.) */}
    <a
        href="#highlights"
        aria-label="Scroll to highlights"
        class="absolute inset-x-0 bottom-8 mx-auto hidden w-max flex-col items-center text-accent md:flex">
        <span class="chevron-bounce text-2xl leading-none">⌄</span>
    </a>
</section>

<style is:global>
    /*  hero entrance animations:
        the hero children stagger in on load;
        the scroll-down chevron bounces.  */

    @keyframes hero-slide-up {
        from { opacity: 0; transform: translateY(80px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .hero-stagger > * {
        animation: hero-slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .hero-stagger > *:nth-child(1) { animation-delay: 0ms; }
    .hero-stagger > *:nth-child(2) { animation-delay: 90ms; }
    .hero-stagger > *:nth-child(3) { animation-delay: 180ms; }
    .hero-stagger > *:nth-child(4) { animation-delay: 270ms; }

    @keyframes chevron-bounce {
        0%, 100% { transform: translateY(0); opacity: 0.5; }
        50%      { transform: translateY(8px); opacity: 1; }
    }
    .chevron-bounce { animation: chevron-bounce 1.8s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
        .hero-stagger > *,
        .chevron-bounce { animation: none; }
    }

    /*  theme the swiper quote carousel to the brand palette. The carousel
        swipes vertically, so it needs a fixed height (the wrapper would
        otherwise collapse). Swiper's bundle CSS forces "margin: auto" on
        ".swiper" (centring it and defeating Tailwind's ml-* utilities), so
        the horizontal offset is set here instead: a right auto-margin keeps
        the carousel off the right edge while a left margin nudges it right.  */
    .hero-quotes.hero-quotes {
        --swiper-theme-color: var(--brand-500);
        --swiper-pagination-bullet-inactive-color: var(--brand-400);
        height: 3rem;
        margin-left:  auto;
        margin-right: 2rem;
        touch-action: pan-y;
    }
    .hero-quotes .swiper-slide {
        height: auto;
    }
</style>
