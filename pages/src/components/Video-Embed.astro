/*  inline demo-video preview for an `ase-media` recording. Renders the
    matching `.jpg` poster (portrait 1200/1400) as a clickable button that
    opens the shared full-viewport modal in `BaseLayout.astro` (wired via the
    `data-video-*` attributes) and plays the `.mp4` served from GitHub Pages.  */

import { mediaBase } from "../data/highlights.ts"

interface Props {
    name:  string
    label: string
}

const { name, label } = Astro.props

const poster = `${mediaBase}/${name}.jpg`
const src    = `${mediaBase}/${name}.mp4`
---
<figure class="m-0">
    <button
        type="button"
        class="usp-video group relative mx-auto block w-full cursor-pointer"
        data-video-src={src}
        data-video-label={label}
        aria-label={`Play demo: ${label}`}
    >
        {/* wave-clip definition: an `objectBoundingBox` clip path (0..1 coords)
            whose lower edge follows the same wave as the former overlay ribbon,
            so the poster is genuinely cut off along the wave instead of being
            painted over. Shared by every `Video-Embed` instance on the page. */}
        <svg class="absolute h-0 w-0" aria-hidden="true">
            <clipPath id="usp-video-wave" clipPathUnits="objectBoundingBox">
                <path
                    d="M0,0 L1,0 L1,0.955 C0.9583,0.943 0.9167,0.943 0.875,0.955 C0.8333,0.967 0.7917,0.967 0.75,0.955 C0.7083,0.943 0.6667,0.943 0.625,0.955 C0.5833,0.967 0.5417,0.967 0.5,0.955 C0.4583,0.943 0.4167,0.943 0.375,0.955 C0.3333,0.967 0.2917,0.967 0.25,0.955 C0.2083,0.943 0.1667,0.943 0.125,0.955 C0.0833,0.967 0.0417,0.967 0,0.955 Z"
                />
            </clipPath>
        </svg>

        <img
            src={poster}
            alt={`Demo: ${label}`}
            loading="lazy"
            class="block aspect-[1200/1000] w-full rounded-t-xl border-x border-t border-border bg-background-secondary object-cover object-top [clip-path:url(#usp-video-wave)]"
        />

        {/* centered play-button overlay (no dimming tint over the poster). */}
        <span class="pointer-events-none absolute inset-0 grid place-items-center">
            <span class="grid h-16 w-16 place-items-center rounded-full bg-[color-mix(in_oklch,var(--accent)_60%,black)]/60 text-2xl font-bold text-white shadow-lg backdrop-blur-xs transition-colors group-hover:bg-[color-mix(in_oklch,var(--accent)_80%,black)]/60">
                ▶
            </span>
        </span>
    </button>
</figure>
