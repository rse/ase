/*  shared scroll-progress logic for the page, driving (when present) the
    Progress-Bar (#scroll-progress), the Progress-Ring (#back-to-top-ring), and
    the back-to-top button's visibility/click (#back-to-top). Each element is
    optional — the logic no-ops for any it doesn't find — so this can sit
    alongside either, both, or neither presentational component.

    Throttled via requestAnimationFrame; vendored/adapted from Astro Rocket.  */
---
<script is:inline>
    (function () {
        const bar  = document.getElementById("scroll-progress")
        const btt  = document.getElementById("back-to-top")
        const ring = document.getElementById("back-to-top-ring")
        let ticking = false
        function update() {
            ticking = false
            const doc = document.documentElement
            const max = doc.scrollHeight - doc.clientHeight
            const p = max > 0 ? doc.scrollTop / max : 0
            if (bar)  bar.style.transform = "scaleX(" + p + ")"
            if (ring) ring.setAttribute("stroke-dashoffset", String(1 - p))
            if (btt) {
                const show = doc.scrollTop > 400
                btt.style.opacity = show ? "1" : "0"
                btt.style.pointerEvents = show ? "auto" : "none"
            }
        }
        function onScroll() {
            if (!ticking) { ticking = true; requestAnimationFrame(update) }
        }
        window.addEventListener("scroll", onScroll, { passive: true })
        window.addEventListener("resize", onScroll)
        if (btt) btt.addEventListener("click", function () {
            window.scrollTo({ top: 0, behavior: "smooth" })

            /*  strip any "#xxx" fragment from the URL (via replaceState, so it
                neither adds a history entry nor re-jumps the page) to ensure we
                really stay at the very top.  */
            if (window.location.hash)
                history.replaceState(null, "", window.location.pathname + window.location.search)
        })
        update()
    })()
</script>
