/*  color-mode (dark/light) toggle. It persists an explicit "ase-color-mode"
    override in localStorage (read before first paint in BaseLayout) and swaps
    the ☾/☀ glyphs via the active `.light` class. Visibility is left to the call
    site via the forwarded `class` (BaseLayout passes `hidden` today, since light
    mode is currently not offered).  */

interface Props {
    class?: string
}

const { class: className = "" } = Astro.props
---
<button
    id="color-mode-toggle"
    type="button"
    aria-label="Toggle color mode"
    class:list={[ "rounded-md border border-border px-2 py-1 text-foreground-secondary transition-colors hover:border-border-strong hover:text-foreground", className ]}
>
    <span class="mode-dark">☾</span><span class="mode-light">☀</span>
</button>

{/* persist an explicit override; dark is the default. */}
<script is:inline>
    (function () {
        const btn = document.getElementById("color-mode-toggle")
        if (!btn) return
        btn.addEventListener("click", function () {
            const root = document.documentElement
            const light = root.classList.toggle("light")
            root.classList.toggle("dark", !light)
            try {
                localStorage.setItem("ase-color-mode", light ? "light" : "dark")
            }
            catch { /*  intentionally ignore inaccessible localStorage  */ }
        })
    })()
</script>

<style is:global>
    /*  swap the color-mode glyphs depending on the active mode.  */
    .mode-light        { display: none; }
    .light .mode-light { display: inline; }
    .light .mode-dark  { display: none; }
</style>

