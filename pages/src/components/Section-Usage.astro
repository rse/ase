/*  "Usage" section: three text/diagram pairs laid out as alternating two-column
    rows (zig-zag), mirroring the highlights rows. Each text block has a brand
    glow behind it; each diagram opens the shared image modal on click.  */

import SectionGlow from "./Section-Glow.astro"
import Diagram     from "./Diagram.astro"
---
<section id="usage" class="relative isolate mx-auto max-w-4xl px-6 py-12 sm:py-16">
    <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-bold sm:text-4xl">
            Understand <span class="text-accent">ASE</span> Philosophy
        </h2>
        <p class="mt-4 text-foreground-secondary">
            <b>ASE</b> is based on
            Dr. Ralf S. Engelschall's Agentic AI Level model,
            where it tries to focus on the "sweet-spot" levels.
            Here <b>ASE</b> provides its
            various skills to let the engineer drive the next steps.
            Some skills are stand-alone, others are part of a particular
            operation mode.
        </p>
    </header>

    <div class="mt-12 flex flex-col gap-12" data-reveal-children>
        {/*  row 1 — text left, agentic-levels diagram right  */}
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
            <div class="relative isolate lg:order-1">
                <SectionGlow variant="text" side="left" />
                <p class="text-sm font-semibold uppercase tracking-wider text-accent">Agentic AI Levels</p>
                <h3 class="mt-3 text-2xl font-bold sm:text-3xl">From Manual To<br/>Fully Autonomous</h3>
                <p class="mt-4 text-foreground-secondary">
                    <b>ASE</b> tries to support
                    the gradual stepping from Agentic AI Level 0 (where the
                    engineer does everything) to Agentic AI Level 4 (where the AI
                    agent does everything), while strongly focusing on the
                    intermediate Agentic AI Levels 1-3 &mdash; the "sweet-spot".
                </p>
                <p class="mt-4 text-foreground-secondary">
                    This means that in <b>ASE</b> the engineer
                    is in the driver seat and always decides and
                    interactively triggers the next operational
                    step, although for some operations multiple
                    steps can be chained or executed in a
                    non-interactive mode.
                </p>
            </div>
            <Diagram class="lg:order-2" src="/assets/agentic-levels.svg" label="agentic levels diagram" />
        </div>

        {/*  row 2 — workflow diagram left, text right (zig-zag)  */}
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
            <div class="relative isolate lg:order-2">
                <SectionGlow variant="text" side="right" />
                <p class="text-sm font-semibold uppercase tracking-wider text-accent">Skills &amp; Workflow</p>
                <h3 class="mt-3 text-2xl font-bold sm:text-3xl">Step-Wise Driving,<br/>You In The Loop</h3>
                <p class="mt-4 text-foreground-secondary">
                    Within the above Agentic AI Levels, <b>ASE</b> provides its
                    various skills to let the engineer trigger the
                    next steps. Some skills are stand-alone, others
                    are part of a particular operation mode that
                    chains skills them into a repeatable workflow.
                    Each skill is named <b><code>/ase-xxx-xxx</code></b>
                    and most of those skills even have useful Unix-style options
                    for adjusting their behavior.
                </p>
            </div>
            <Diagram class="lg:order-1" src="/assets/workflow.svg" label="ASE usage workflow diagram" />
        </div>

        {/*  row 3 — text left, operation-modes diagram right  */}
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
            <div class="relative isolate lg:order-1">
                <SectionGlow variant="text" side="left" />
                <p class="text-sm font-semibold uppercase tracking-wider text-accent">Operation Modes</p>
                <h3 class="mt-3 text-2xl font-bold sm:text-3xl">Advanced Workflows, Maximum Flexibility</h3>
                <p class="mt-4 text-foreground-secondary">
                    On top of the usual Agentic AI Coding tool modes
                    <i>Ad-Hoc Mode</i> and <i>Plan Mode</i>,
                    <b>ASE</b> adds three essential operation modes:
                    The <i>Task Mode</i> is a <i>Plan Mode</i>
                    "on steroids". The <i>Funnel Mode</i>
                    adds power to the steps before the <i>Task Mode</i>.
                    The special <i>Sync Mode</i> lifts the plan to entire
                    specification/architecture artifacts and allows
                    to reconcile the code and documentation to those
                    artifacts.
                </p>
            </div>
            <Diagram class="lg:order-2" src="/assets/operation-modes.svg" label="ASE operation modes diagram" />
        </div>
    </div>
</section>
