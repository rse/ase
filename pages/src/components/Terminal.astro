/*  reusable terminal-style box: a titled "window" listing one or more shell
    commands, each on a "❯" prompt row with a copy button (copy behaviour wired
    globally by the Clipboard-Copy component in BaseLayout). The mono styling
    mirrors the hero prompt for a consistent command-line look.

    `commands` is the list of command strings (one prompt row each); `title` is
    the title-bar label; `class` is forwarded to the outer wrapper so callers
    set their own margin/width (e.g. "mx-auto mt-12 max-w-2xl").  */

interface Props {
    commands: string[]
    prefix?:  string
    title?:   string
    copy?:    boolean
    class?:   string
}

const { commands, prefix = "Terminal", title = "", copy = false, class: className = "" } = Astro.props

/*  split a command into runs, flagging any **...** span so it can be tinted in
    the accent colour while the rest stays plain. This lets callers explicitly
    highlight arbitrary parts of a command.  */
const tokenize = (cmd: string) =>
    cmd.split(/(\*\*[^*]*\*\*)/).filter((part) => part !== "").map((part) => ({
        text: /^\*\*[^*]*\*\*$/.test(part) ? part.slice(2, -2) : part,
        meta: /^\*\*[^*]*\*\*$/.test(part)
    }))

/*  the raw command without the **...** highlight markers, so the copied text
    stays unchanged.  */
const plain = (cmd: string) => cmd.replace(/\*\*([^*]*)\*\*/g, "$1")
---
<div class={className}>
    <div class="overflow-hidden rounded-xl border border-border-strong bg-background-elevated/60 text-[0.7875rem] leading-snug shadow-xl sm:text-[0.9rem]">
        <div class="flex items-center gap-2 border-b border-border/60 px-4 py-1 bg-accent/10">
            <span class="h-3 w-3 rounded-full bg-[var(--brand-400)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--brand-500)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--brand-600)]"></span>
            <span class="ml-2 text-foreground">{prefix}{title && ":"}</span>
            {title && <span class="text-accent">{title}</span>}
        </div>
        <div class="flex flex-col gap-0 px-4 py-2">
            {commands.map((cmd) => (
                <div class="group flex items-start gap-3 font-mono tracking-[-0.03em]">
                    <span class="select-none text-accent">❯</span>
                    <code class="code-plain flex-1 text-foreground">{tokenize(cmd).map((t) => (
                        t.meta ? <span class="text-accent">{t.text}</span> : t.text
                    ))}</code>
                    {copy && (
                        <button
                            type="button"
                            class="copy-cmd shrink-0 rounded-md border border-border px-2 py-1 text-xs text-foreground-muted transition hover:border-border-strong hover:text-foreground"
                            data-copy={plain(cmd)}
                            aria-label="Copy command"
                        >Copy</button>
                    )}
                </div>
            ))}
        </div>
    </div>
</div>
