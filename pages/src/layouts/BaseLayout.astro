/*  base layout for the ASE site: dark-by-default <html>, SEO head, a floating
    header with a scroll-progress bar, a footer, and a back-to-top button with
    a scroll-progress ring. The scroll-reveal IntersectionObserver and the
    scroll-progress logic are vendored and adapted from Astro Rocket (MIT).  */

import                    "../styles/theme.css"
import { site }      from "../data/site.ts"
import ThemeInit     from "../components/Theme-Init.astro"
import PageHeader    from "../components/Page-Header.astro"
import PageFooter    from "../components/Page-Footer.astro"
import ModalVideo    from "../components/Modal-Video.astro"
import ModalImage    from "../components/Modal-Image.astro"
import ModalHelp     from "../components/Modal-Help.astro"
import ModalQR       from "../components/Modal-QR.astro"
import ProgressRing  from "../components/Progress-Ring.astro"
import Progress      from "../components/Progress.astro"
import ClipboardCopy from "../components/Clipboard-Copy.astro"
import ScrollReveal  from "../components/Scroll-Reveal.astro"
import ScrollSpy     from "../components/Scroll-Spy.astro"

interface Props {
    title?:       string
    description?: string
}

const { title, description } = Astro.props

const pageTitle = title ?? site.title
const pageDesc  = description ?? site.description
const canonical = new URL(Astro.url.pathname, Astro.site).href
---
<!DOCTYPE html>
<html lang="en" class="dark">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/assets/ase-logo.svg" />
        <link rel="canonical" href={canonical} />
        <meta name="theme-color" content={site.themeColor} />

        <title>{pageTitle}</title>
        <meta name="description" content={pageDesc} />
        <meta name="author" content={site.author} />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDesc} />
        <meta property="og:url" content={canonical} />
        <meta name="twitter:card" content="summary_large_image" />

        <ThemeInit/>
    </head>
    <body>
        <PageHeader/>

        <main>
            <slot/>
        </main>

        <PageFooter/>

        <ModalVideo/>
        <ModalImage/>
        <ModalHelp/>
        <ModalQR/>

        <ProgressRing/>
        <Progress/>

        <ScrollReveal/>
        <ScrollSpy/>

        <ClipboardCopy/>
    </body>
</html>
